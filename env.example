HOST=0.0.0.0  # NoneBot / OneBot 监听地址
PORT=8080  # NoneBot / OneBot 监听端口
COMMAND_START=["/"]  # 配置命令起始字符
COMMAND_SEP=["."]  # 配置命令分割字符

# ===========================================
# Web Admin 配置
# ===========================================
WEB_HOST=0.0.0.0  # Web Admin API 监听地址
WEB_PORT=8081  # Web Admin API 监听端口
WEB_SECRET_KEY=change-me-to-a-long-random-string  # JWT 签名 & Cookie 加密密钥（必填）
WEB_ADMIN_ENABLED=true  # 设为 false 可禁用 Web Admin 服务

# 数据库（nonebot-plugin-orm）
# SQLite 默认路径由 nonebot-plugin-localstore 管理，也可指定绝对路径：
SQLALCHEMY_DATABASE_URL=sqlite+aiosqlite:///data/cyxcbot.db
# PostgreSQL 示例：
# SQLALCHEMY_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/cyxcbot

# 数据库在 bot.py 启动时自动初始化（建表 / 应用 shared/db/migrations 中的迁移）
# 开发新 schema 时可用 nb-cli：nb orm revision / nb orm upgrade

# JWT 可选配置
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# 日志配置
LOG_LEVEL=INFO
