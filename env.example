HOST=0.0.0.0  # 配置 NoneBot 监听的 IP / 主机名
PORT=8080  # 配置 NoneBot 监听的端口
COMMAND_START=["/"]  # 配置命令起始字符
COMMAND_SEP=["."]  # 配置命令分割字符

# 超级用户配置
SUPERUSERS=["你的QQ号"]

# 状态检查插件配置
# 允许查询状态的QQ号列表（可选，默认使用SUPERUSERS）
# STATUS_CHECK_ALLOWED_QQ=["你的QQ号"]

# 是否显示详细状态信息（默认：true）
STATUS_CHECK_SHOW_DETAILED=true

# 是否显示机器人运行时间（默认：true）
STATUS_CHECK_SHOW_UPTIME=true

# 是否显示内存使用情况（默认：true）
STATUS_CHECK_SHOW_MEMORY=true

# 日志配置
# 设置程序日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
# DEBUG: 显示所有调试信息（包括第三方库）
# INFO: 显示一般信息（推荐生产环境）
# WARNING: 只显示警告和错误
LOG_LEVEL=INFO

# UP主动态监控插件配置
# UP主UID-群组映射配置（JSON格式）
# 格式：{"UP主UID": ["群组ID1", "群组ID2"], "UP主UID2": ["群组ID3"]}
# 只有在此映射中配置的UP主才会进行动态监控
DYNAMIC_MONITOR_MAPPING={"12345678": ["123456789", "987654321"], "87654321": ["111111111"]}

# 监控间隔时间（秒，默认：30）
# 建议范围：30-3600秒（0.5分钟到1小时）
DYNAMIC_MONITOR_INTERVAL=30

# 是否启用动态截图（默认：true）
# true: 推送消息中包含动态网页截图
# false: 发送 API 解析的动态正文与图片（不启动 Playwright）
DYNAMIC_ENABLE_SCREENSHOT=true

# B站Cookie配置（可选，用于提高API请求成功率）
# 开发者工具Network面板找到dynamic_new请求，复制Cookie
# 示例：
# BILIBILI_COOKIE=SESSDATA=xxxxx;DedeUserID=xxxxx;bili_jct=xxxxx

# ===========================================
# B站直播监控插件配置（主动监控，无需依赖blrec）
# ===========================================
# 房间号-群组映射配置（JSON格式）
# 格式：{"房间号": ["群组ID1", "群组ID2"], "房间号2": ["群组ID3"]}
# 注意：此配置独立于 STREAMER_GROUP_MAPPING，用于主动监控
LIVE_MONITOR_MAPPING={"12345678": ["123456789", "987654321"]}

# 直播状态检查间隔（秒，默认：60，最小：30）
# 如果启用了WebSocket，此间隔作为备用轮询间隔（会自动乘以5）
LIVE_MONITOR_INTERVAL=60

# 是否在通知中包含详细房间信息（默认：true）
LIVE_MONITOR_INCLUDE_INFO=true

# 是否启用 WebSocket 实时监控（默认：true）
# true: 使用 WebSocket 弹幕客户端实时监控（秒级响应，推荐）
# false: 仅使用 API 轮询（根据 LIVE_MONITOR_INTERVAL 间隔）
LIVE_MONITOR_USE_WEBSOCKET=true
