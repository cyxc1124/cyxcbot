HOST=0.0.0.0  # 配置 NoneBot 监听的 IP / 主机名
PORT=8080  # 配置 NoneBot 监听的端口
COMMAND_START=["/"]  # 配置命令起始字符
COMMAND_SEP=["."]  # 配置命令分割字符

# 超级用户配置
SUPERUSERS=["你的QQ号"]

# B站直播通知插件配置
# 房间号-群组映射配置（JSON格式）
# 格式：{"房间号": ["群组ID1", "群组ID2"], "房间号2": ["群组ID3"]}
# 只有在此映射中配置的房间号才会发送通知
STREAMER_GROUP_MAPPING={"12345678": ["123456789", "987654321"], "87654321": ["111111111"]}

# 是否包含房间信息
INCLUDE_ROOM_INFO=true

# 状态检查插件配置
# 允许查询状态的QQ号列表（可选，默认使用SUPERUSERS）
# STATUS_CHECK_ALLOWED_QQ=["你的QQ号"]

# 是否显示详细状态信息（默认：true）
STATUS_CHECK_SHOW_DETAILED=true

# 是否显示机器人运行时间（默认：true）
STATUS_CHECK_SHOW_UPTIME=true

# 是否显示内存使用情况（默认：true）
STATUS_CHECK_SHOW_MEMORY=true

# UP主动态监控插件配置
# UP主UID-群组映射配置（JSON格式）
# 格式：{"UP主UID": ["群组ID1", "群组ID2"], "UP主UID2": ["群组ID3"]}
# 只有在此映射中配置的UP主才会进行动态监控
DYNAMIC_MONITOR_MAPPING={"12345678": ["123456789", "987654321"], "87654321": ["111111111"]}

# 监控间隔时间（秒，默认：300，即5分钟）
# 建议范围：30-3600秒（0.5分钟到1小时）
DYNAMIC_MONITOR_INTERVAL=300


# 是否启用动态截图（默认：true）
# true: 在推送消息中包含动态网页截图；false: 只发送文字消息
# 注意：启用截图需要安装playwright库
DYNAMIC_ENABLE_SCREENSHOT=true
